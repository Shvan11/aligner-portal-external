# Aligner Portal (external) — environment
# Set these in Cloudflare Pages › Settings › Environment variables.

# The single Supabase mirror project (raw clinic schema, RLS-locked).
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Main app base URL (cloudflared tunnel). The portal posts its Cloudflare-Access
# JWT here to mint a short-lived, dr_id-scoped Supabase token that RLS keys off.
# POST {VITE_MAIN_APP_URL}/api/aligner-portal/token
VITE_MAIN_APP_URL=https://remote.shwan-orthodontics.com
