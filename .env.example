# Aligner Portal (external) — environment
# Set these in Cloudflare Pages › Settings › Environment variables.

# The single Supabase mirror project (raw clinic schema, RLS-locked).
# The portal posts its Cloudflare-Access JWT to the `aligner-portal-auth` Edge
# Function (at {VITE_SUPABASE_URL}/functions/v1/aligner-portal-auth/token) to mint
# a short-lived, dr_id-scoped Supabase token that RLS keys off — always-on, no
# clinic home-server dependency.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
